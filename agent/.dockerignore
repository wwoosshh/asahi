# 빌드 컨텍스트가 agent/ 이므로(Root Directory=agent, deploy/railway-셋업.md 참고),
# 아래 경로들은 모두 agent/ 기준이다. 컨텍스트 전송량을 줄이고 비밀값·불필요 파일이
# 이미지에 섞이는 것을 막는다.

# 빌드 산출물 / 의존성 — 컨테이너 안에서 새로 설치·빌드한다.
node_modules
dist

# 비밀값 — 이미지에 절대 넣지 않는다. 런타임에 Railway Variables 로 주입.
.env
.env.*

# 테스트 / 개발 전용 파일 — 런타임에 불필요.
tests
vitest.config.ts

# 문서 / 잡파일.
*.md
윈도우자동실행.txt

# 기타 흔한 노이즈.
.git
.gitignore
npm-debug.log*
