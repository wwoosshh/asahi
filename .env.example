# 디스코드 봇 토큰 (Discord Developer Portal > Bot)
DISCORD_TOKEN=
# 소유자(본인)의 디스코드 사용자 ID — 이 사람의 메시지에만 반응
DISCORD_OWNER_ID=
# Postgres(Supabase) 연결 문자열 — 필수
DATABASE_URL=
# (선택) DM 외에 반응할 서버 채널 ID
DISCORD_CHANNEL_ID=
# (선택) claude setup-token 으로 발급한 구독 OAuth 토큰 — cloud(DEPLOY_TARGET=cloud)에선 사실상 필수, 없으면 SDK 인증 실패
CLAUDE_CODE_OAUTH_TOKEN=
# (선택) 세션 유휴 종료 시간(분), 기본 30
SESSION_IDLE_MINUTES=
# (선택) 시간당 최대 턴 수(구독 한도 보호), 기본 30 — 하위호환용
MAX_TURNS_PER_HOUR=
# (선택) 멀티유저 한도 — 유저별 시간당 상한, 기본 20
MAX_TURNS_PER_HOUR_PER_USER=
# (선택) 멀티유저 한도 — 전역 시간당 상한, 기본 40
MAX_TURNS_PER_HOUR_GLOBAL=
# (선택, 현재 미사용) 소유자는 무제한 정책이라 예약분이 필요 없음 — 하위호환 위해 남겨둠
OWNER_RESERVE=
# (선택) 런타임 데이터 경로 재정의 — 기본값은 리포 루트의 data/store, data/memory
DATA_DIR=
MEMORY_DIR=
# (선택) 배포 대상: local 또는 cloud, 기본 local — cloud 면 소유자 DM 이라도 PC 파일/Bash 도구를 비활성한다
DEPLOY_TARGET=
# (선택) 사용할 Claude 모델, 기본 claude-opus-4-8 (config.ts)
ANTHROPIC_MODEL=

# ── 로컬 워커 전용(하이브리드 조각3) — src/worker.ts 실행 시에만 필요, 봇(index.ts)에는 영향 없음 ──
# 중요(보안): 워커는 현재 소유자(DISCORD_OWNER_ID) 전용입니다. WORKER_USER_ID 는 반드시 소유자
# 자신의 디스코드 ID 여야 합니다 — 손님 ID 를 넣어도 봇(core.ts)이 손님 DM 은 위임하지 않으므로
# 동작하지 않습니다(정책: 손님 DM 은 항상 이 봇이 처리). 또한 DATABASE_URL 은 소유자만 소지해야
# 합니다 — 손님에게 공유하면 그 손님이 직접 워커를 띄워 WORKER_USER_ID=소유자ID 로 설정해 소유자를
# 사칭, PC 전권(파일/Bash)을 탈취할 수 있습니다(WORKER_SECRET 검증·행 단위 권한(RLS)은 손님 워커
# 지원을 위한 후속 과제이며 아직 미구현입니다).
# 이 워커가 담당할(=자기 PC 에서 작업을 실행해 줄) 디스코드 사용자 ID. 필수. (= DISCORD_OWNER_ID 값)
WORKER_USER_ID=
# (선택, 현재 로드만 함) 워커 인증용 비밀값 — 추후 사용 예정
WORKER_SECRET=
